# CodeClaw Environment Variables
# ==============================
# Never commit real tokens or secrets.
# Never store Jira/Slack/GitHub tokens in config files.
# Secrets must go to OS keychain or environment variables.

# OpenAI-Compatible API Key (for AgentBackend LLM provider)
# Required if agentBackend.provider is set to "openai-compatible"
# config.json stores only the env var name, never the key itself.
CODECLAW_OPENAI_API_KEY=

# Jira API token (optional)
# Never store in config.json. config.json stores the env var name.
# Preferred: CODECLAW_JIRA_TOKEN=<your-jira-api-token>

# Slack bot token (optional)
# Never store in config.json. config.json stores the env var name.
# Preferred: CODECLAW_SLACK_TOKEN=xoxb-<your-slack-bot-token>
