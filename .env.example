# Never commit real tokens or secrets.
# Never store Jira/Slack/GitHub tokens in config files.
# Secrets must go to OS keychain or environment variables.

# CodeClaw environment variables
# Legacy AITEAM_* variables are also supported as fallback.

# Jira API token (never store in config.json)
# Preferred: CODECLAW_JIRA_TOKEN=<your-jira-api-token>
# Legacy fallback: AITEAM_JIRA_TOKEN

# Slack bot token (never store in config.json)
# Preferred: CODECLAW_SLACK_TOKEN=xoxb-<your-slack-bot-token>
# Legacy fallback: AITEAM_SLACK_TOKEN
