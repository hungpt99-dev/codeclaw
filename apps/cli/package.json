{
  "name": "@codeclaw/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "bin": {
    "codeclaw": "./dist/index.js",
    "aiteam": "./dist/index.js"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "tsc",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "@codeclaw/adapters": "workspace:*",
    "@codeclaw/core": "workspace:*",
    "@codeclaw/server": "workspace:*",
    "@codeclaw/memory": "workspace:*",
    "@codeclaw/shared": "workspace:*",
    "@codeclaw/storage": "workspace:*",
    "commander": "^13.1.0"
  }
}
