{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@aiteam/shared": ["packages/shared/src/index.ts"],
      "@aiteam/core": ["packages/core/src/index.ts"],
      "@aiteam/storage": ["packages/storage/src/index.ts"],
      "@aiteam/adapters": ["packages/adapters/src/index.ts"],
      "@aiteam/memory": ["packages/memory/src/index.ts"]
    }
  }
}
